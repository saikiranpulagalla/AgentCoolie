# Local combined environment example. Do not place real secrets in this file.
# In deployed environments, use Railway/Firebase variables and Supabase app_secrets.

# Frontend (Vite exposes only VITE_* values to the browser)
VITE_FIREBASE_API_KEY=replace_me
VITE_FIREBASE_PROJECT_ID=replace_me
VITE_FIREBASE_APP_ID=replace_me
VITE_API_URL=http://localhost:8000

# Backend identity and storage
FIREBASE_PROJECT_ID=replace_me
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"replace_me"}
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_me

# Local runtime. Public deployments must use ENV=production, DEBUG=false,
# HTTPS CORS origins, rediss://, and a unique SESSION_SECRET_KEY (32+ chars).
ENV=development
DEBUG=true
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=["http://localhost:5173","http://localhost:8000"]
SESSION_SECRET_KEY=replace_with_a_long_random_secret
OAUTH_STATE_MAX_AGE_SECONDS=600
DEMO_BILLING_ENABLED=false

# AI and search providers
GOOGLE_AI_API_KEY=replace_me
GOOGLE_AI_API_KEYS=["replace_me"]
GEMINI_VISION_API_KEYS=["replace_me"]
GROQ_API_KEYS=["replace_me"]
SERPAPI_API_KEY=replace_me

# Gmail OAuth and n8n
GOOGLE_CLIENT_ID=replace_me.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace_me
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/oauth/google/callback
ALLOW_DEV_OAUTH_UID_FALLBACK=false
N8N_BASE_URL=https://your-n8n-host
N8N_TOOL_SECRET=replace_with_a_long_random_secret

# Redis, task execution, and webhook deduplication
REDIS_URL=redis://localhost:6379/0
REDIS_MEMORY_TTL_SECONDS=86400
REDIS_MEMORY_CONTEXT_EXCHANGES=5
REDIS_MEMORY_MAX_MESSAGES=30
TASK_EXECUTION_LEASE_SECONDS=300
WEBHOOK_IDEMPOTENCY_TTL_SECONDS=86400

# Upload safety limits
MAX_ATTACHMENT_COUNT=4
MAX_UPLOAD_BYTES=10485760
MAX_CHAT_MESSAGE_CHARS=12000
MAX_ATTACHMENT_CONTEXT_CHARS=60000
MAX_IMAGE_PIXELS=40000000
AI_REQUEST_TIMEOUT_SECONDS=60

# Twilio / WhatsApp (optional)
TWILIO_ACCOUNT_SID=replace_me
TWILIO_AUTH_TOKEN=replace_me
TWILIO_FROM_NUMBER=+10000000000
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_VALIDATE_WEBHOOK_SIGNATURE=true
WHATSAPP_VERIFY_TOKEN=replace_me
WHATSAPP_WEBHOOK_SECRET=replace_me
WHATSAPP_VERIFICATION_TTL_MINUTES=15
WHATSAPP_VERIFICATION_RESEND_SECONDS=60
