# Firebase Configuration (Client-side)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# Frontend API URL
VITE_API_URL=http://localhost:8000
VITE_CLIENT_WEBHOOK_URL=http://localhost:8000/api/webhook/proxy

# Firebase Admin Configuration (Server-side)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# OR use file path instead:
# FIREBASE_ADMIN_CREDENTIALS_PATH=./path/to/serviceAccount.json

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# AI Provider Configuration
# Choose one: google, openai
EMBEDDING_PROVIDER=google

# Google AI (Gemini) and Groq fallback
GOOGLE_AI_API_KEY=your_google_ai_api_key
GOOGLE_AI_API_FALLBACK_KEY=your_google_ai_fallback_key
GOOGLE_AI_API_KEYS=["optional_text_key_1","optional_text_key_2"]
GEMINI_VISION_API_KEYS=["optional_image_key_1","optional_image_key_2"]
GROQ_API_KEY=your_groq_api_key
GROQ_API_KEYS=["optional_groq_key_1","optional_groq_key_2"]
GROQ_MODEL=llama-3.1-8b-instant
# Available models: gemini-1.5-flash, gemini-1.5-pro, gemini-2.0-flash
GEMINI_MODEL=gemini-1.5-flash
GEMINI_VISION_MODEL=gemini-1.5-flash

# Web search
SERPAPI_API_KEY=your_serpapi_key

# OpenAI (Optional)
# OPENAI_API_KEY=sk-...
# Available models: gpt-4o, gpt-4o-mini, gpt-4-turbo
# OPENAI_MODEL=gpt-4o-mini

# Google OAuth (for Gmail integration)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/oauth/google/callback
FRONTEND_URL=http://localhost:5173

# n8n Gmail workflow
N8N_BASE_URL=https://your-n8n-host
N8N_GMAIL_ACTION_PATH=/webhook/gmail-action
N8N_GMAIL_CREDENTIALS_PATH=/webhook/save-gmail-credentials
N8N_TOOL_SECRET=use-a-long-random-secret

# YouTube API (Optional)
# YOUTUBE_API_KEY=your_youtube_api_key

# Redis short-term memory
REDIS_URL=redis://localhost:6379/0
REDIS_MEMORY_CONTEXT_EXCHANGES=5
REDIS_MEMORY_MAX_MESSAGES=30
REDIS_MEMORY_TTL_SECONDS=86400

# Twilio call reminders and WhatsApp
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+10000000000
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_VALIDATE_WEBHOOK_SIGNATURE=true
WHATSAPP_VERIFY_TOKEN=your_verify_token
WHATSAPP_WEBHOOK_SECRET=your_webhook_secret
CALL_REMINDER_POLL_INTERVAL_SECONDS=30

# LangSmith tracing
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your_langsmith_key
LANGSMITH_PROJECT=agentcoolie-production

# Server Configuration
HOST=0.0.0.0
PORT=8000
ENV=development
DEBUG=true
APP_TIMEZONE=Asia/Kolkata

# Session Security (Change in production!)
SESSION_SECRET_KEY=your-secret-key-change-in-production
OAUTH_STATE_MAX_AGE_SECONDS=600
DEMO_BILLING_ENABLED=false

# Upload limits
MAX_ATTACHMENT_COUNT=4
MAX_UPLOAD_BYTES=26214400

# CORS Origins
CORS_ORIGINS=["http://localhost:5173","http://localhost:8000"]
