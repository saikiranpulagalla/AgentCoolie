# CoolieAssistant Backend Environment Configuration

# Server Configuration
HOST=0.0.0.0
PORT=8000
ENV=development
DEBUG=true

# Firebase Configuration
# Option 1: Service account JSON file path
FIREBASE_ADMIN_CREDENTIALS_PATH=/path/to/serviceAccount.json

# Option 2: Service account JSON as string (set ONE of the above)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

FIREBASE_PROJECT_ID=your-project-id

# Supabase Configuration (REQUIRED)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Provider Configuration
# Choose ONE: google, openai
EMBEDDING_PROVIDER=google

# OpenAI (if using openai provider)
OPENAI_API_KEY=sk-...

# Google Generative AI (if using google provider)
GOOGLE_AI_API_KEY=AIzaSy...
GOOGLE_AI_API_FALLBACK_KEY=AIzaSy...
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.1-8b-instant

# LangSmith tracing (Optional)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=lsv2_pt_...
LANGSMITH_PROJECT=agentcoolie-production

# Google OAuth Configuration (Optional - for Gmail)
GOOGLE_CLIENT_ID=...client.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=...
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/gmail/oauth/callback

# YouTube API (Optional)
YOUTUBE_API_KEY=...

# Twilio call reminders (Optional)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+10000000000
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_VALIDATE_WEBHOOK_SIGNATURE=true
CALL_REMINDER_POLL_INTERVAL_SECONDS=30

# n8n Gmail tool webhooks
N8N_BASE_URL=https://your-n8n-host
N8N_GMAIL_ACTION_PATH=/webhook/gmail-action
N8N_GMAIL_CREDENTIALS_PATH=/webhook/save-gmail-credentials
N8N_TOOL_SECRET=use-a-long-random-secret

# Session Security (Change in production!)
SESSION_SECRET_KEY=your-secret-key-change-in-production

# Redis short-term chat memory
# Redis Cloud usually gives redis:// or rediss://. Use rediss:// when TLS is enabled.
# Example: rediss://default:your_redis_password@your-redis-host:your-port/0
REDIS_URL=rediss://default:your_redis_password@your-redis-host:your-port/0
REDIS_MEMORY_TTL_SECONDS=86400
REDIS_MEMORY_CONTEXT_EXCHANGES=5
REDIS_MEMORY_MAX_MESSAGES=10

# Supabase long-term memory
LONG_TERM_MEMORY_ENABLED=true
LONG_TERM_MEMORY_CONTEXT_LIMIT=20
LONG_TERM_MEMORY_MIN_IMPORTANCE=0.65

# CORS Configuration
CORS_ORIGINS=["http://localhost:5173","http://localhost:8000"]
